# =============================================================================
# USI Payout Service - Environment Variables (Template)
# =============================================================================
# Sensitive values SHOULD be sourced from AWS Secrets Manager / KMS in any
# non-local environment. Values here act as a fallback only when the secret
# manager is disabled or a key is missing.
# Never commit a real .env file. .env is gitignored.
# =============================================================================

# ----- Runtime ---------------------------------------------------------------
NODE_ENV=development
PORT=8080
HOST=0.0.0.0
APP_NAME=usi-payout-service
LOG_LEVEL=info
TRUST_PROXY=1

# ----- Internal API authentication (strong, multi-factor) --------------------
# Required in production. JSON array of clients. Each entry:
#   {
#     "clientId":          "ledger-service",
#     "apiKey":            "ak_live_xxx",            # x-api-key header
#     "secretHeaderName":  "x-app-secret-token",     # name of the secret header
#     "secretHeaderValue": "sv_live_xxx",            # expected value
#     "signingSecret":     "hmac_signing_key_xxx",   # HMAC-SHA256 key
#     "scopes":            ["payout", "read"]
#   }
# Both the header NAME and VALUE come from this secret — the name is treated
# as a secret too. Put the whole JSON into Secrets Manager.
INTERNAL_CLIENTS=

# When STRICT_AUTH=true, the multi-factor flow is enforced even outside prod.
# Auto-enabled when INTERNAL_CLIENTS is non-empty.
STRICT_AUTH=false

# Acceptable clock skew for x-timestamp (seconds) and nonce TTL (seconds).
SIGNATURE_SKEW_SEC=300
NONCE_TTL_SEC=900

# ----- Legacy auth (dev / fallback) -----------------------------------------
INTERNAL_JWT_SECRET=change-me-in-secrets-manager
INTERNAL_JWT_AUDIENCE=usi-payout-service
INTERNAL_JWT_ISSUER=internal-auth
INTERNAL_API_KEYS=

# ----- Rate limiting ---------------------------------------------------------
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300

# ----- Redis (required in prod for nonces + idempotency + rate limit) -------
# Single REDIS_URL is shared by rate limit, replay protection and idempotency.
REDIS_URL=

# ----- Idempotency (payout endpoints) ---------------------------------------
# Cache TTL for successful idempotent responses (seconds). Default 86400 = 24h.
IDEMPOTENCY_TTL_SEC=86400
# Lock TTL while a first request is still in flight (seconds).
IDEMPOTENCY_LOCK_TTL_SEC=300

# ----- AWS / Secrets Manager -------------------------------------------------
AWS_REGION=ap-south-1
SECRETS_MANAGER_ENABLED=false
SECRETS_MANAGER_SECRET_ID=usi-payout-service/prod
KMS_KEY_ID=

# ----- USI / RemitONE 3rd Party API ------------------------------------------
USI_BASE_URL=https://test4.remit.by/universalsecuritiestest/ws
USI_USERNAME=
USI_PASSWORD=
USI_PIN=
USI_DATA_INTEGRITY_KEY=
USI_TIMEOUT_MS=15000
USI_MAX_RETRIES=2
USI_MAX_SOCKETS=200

# ----- Logging / audit storage ----------------------------------------------
# In Docker the recommended path is /var/log/usi-payout (the image sets that
# via ENV and creates the dir as the `app` user). For bare-metal / local
# `npm start`, point these at a writable directory you own — the default
# below works out of the box.
LOG_DIR=./logs
AUDIT_LOG_DIR=./logs/audit
LOG_RETENTION_DAYS=30
LOG_MAX_SIZE=50m
AUDIT_ENCRYPTION_KEY=

# ----- Clustering ------------------------------------------------------------
CLUSTER_WORKERS=0   # 0 = use os.cpus().length
