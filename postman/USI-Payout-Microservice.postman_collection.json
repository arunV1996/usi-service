{
  "info": {
    "name": "USI Payout Microservice (Internal)",
    "description": "Postman collection for the internal USI Payout microservice. All endpoints are mounted under /v1 and require authentication (x-api-key OR Bearer JWT). Each request includes a correlation id and returns a uniform { status, data, meta } envelope.\n\nSet the `baseUrl` and `apiKey` collection variables before sending. Use `bearerToken` instead of `apiKey` if you prefer JWT.\n\nMicroservice repo: usi-service",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "9d1f2c0e-1a4a-4f8a-9bd0-000000000001"
  },
  "auth": {
    "type": "apikey",
    "apikey": [
      { "key": "key", "value": "x-api-key", "type": "string" },
      { "key": "value", "value": "{{apiKey}}", "type": "string" },
      { "key": "in", "value": "header", "type": "string" }
    ]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080", "type": "string" },
    { "key": "apiKey", "value": "replace-with-internal-api-key", "type": "string" },
    { "key": "bearerToken", "value": "", "type": "string" },
    { "key": "remitterId", "value": "10005", "type": "string" },
    { "key": "beneficiaryId", "value": "11", "type": "string" },
    { "key": "transRef", "value": "RA000263000102", "type": "string" },
    { "key": "agentTransRef", "value": "AGT-TEST-001", "type": "string" },
    { "key": "transSessionId", "value": "830016270356710161", "type": "string" }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Auto-generate a correlation id for every request unless caller set one.",
          "if (!pm.request.headers.has('x-correlation-id')) {",
          "  pm.request.headers.add({ key: 'x-correlation-id', value: 'pm-' + Date.now().toString(36) + '-' + Math.random().toString(36).slice(2, 10) });",
          "}"
        ]
      }
    }
  ],
