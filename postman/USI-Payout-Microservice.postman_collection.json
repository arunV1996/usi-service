              "raw": "{\n  \"remitter_id\": 10005,\n  \"beneficiary_id\": 11,\n  \"destination_country\": \"India\",\n  \"agent_trans_ref\": \"{{agentTransRef}}\",\n  \"trans_type\": \"Cash Collection\",\n  \"purpose\": \"1\",\n  \"source_of_income\": \"1\",\n  \"payment_method\": \"74\",\n  \"service_level\": \"1\",\n  \"sms_confirmation\": \"f\",\n  \"sms_notification\": \"f\",\n  \"amount_type\": \"DESTINATION\",\n  \"amount_to_send\": 1000\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const j = pm.response.json();",
                  "  if (j && j.data && j.data.trans_session_id) {",
                  "    pm.collectionVariables.set('transSessionId', j.data.trans_session_id);",
                  "  }",
                  "}"
                ]
              }
            }
