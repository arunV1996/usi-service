            },
            "description": "Mounted at `/v1/transactions/` with a trailing slash so the path matches what the server expects for idempotency.\n\nThe collection-level pre-request script:\n  - signs the request with HMAC-SHA256\n  - generates a fresh Idempotency-Key (UUID) unless `idempotencyKey` is pinned\n\nThe per-request test script captures `trans_session_id` so the next `confirmTransaction` call just works."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Persist trans_session_id and audit_id for subsequent calls.",
                  "try {",
                  "  const j = pm.response.json();",
                  "  if (j && j.data && j.data.trans_session_id) {",
                  "    pm.collectionVariables.set('transSessionId', j.data.trans_session_id);",
                  "  }",
                  "  const audit = (j && j.meta && j.meta.audit_id) || (j && j.error && j.error.audit_id);",
                  "  if (audit) pm.collectionVariables.set('auditId', audit);",
                  "  if (pm.response.headers && pm.response.headers.get('x-idempotent-replay') === 'true') {",
                  "    console.log('[idempotency] replayed cached response (stored at ' + pm.response.headers.get('x-idempotent-stored-at') + ')');",
                  "  }",
                  "} catch (_) { /* non-JSON */ }"
                ]
              }
            }
          ]
        },
