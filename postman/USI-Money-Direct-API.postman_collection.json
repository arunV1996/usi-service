{
  "info": {
    "name": "USI Money / RemitONE Direct API",
    "description": "Direct calls to the USI Money (RemitONE) Agent Partner WebServices, useful for debugging and SOC/pen-test reproduction. Every request is a POST with application/x-www-form-urlencoded body.\n\nA collection-level pre-request script automatically injects `username`, `password`, `pin` from collection variables, and (if `dataIntegrityKey` is set) computes the SHA-256 `data_integrity_hash` per the spec — concatenating all POST params except username/password/pin/id1_scan/id2_scan, then appending the integrity key.\n\nDO NOT paste real production credentials into the variables. Use a dedicated Postman environment file checked into a private store, or override at runtime.\n\nBase URL pattern: `{{baseUrl}}/<group>/<method>`. Example for the test environment:\n  https://test4.remit.by/universalsecuritiestest/ws",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "9d1f2c0e-1a4a-4f8a-9bd0-000000000002"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://test4.remit.by/universalsecuritiestest/ws", "type": "string" },
    { "key": "username", "value": "", "type": "string" },
    { "key": "password", "value": "", "type": "string" },
    { "key": "pin", "value": "", "type": "string" },
    { "key": "dataIntegrityKey", "value": "", "type": "string" },
    { "key": "remitterId", "value": "10005", "type": "string" },
    { "key": "beneficiaryId", "value": "11", "type": "string" },
    { "key": "transRef", "value": "RA000263000102", "type": "string" },
    { "key": "agentTransRef", "value": "AGT-TEST-001", "type": "string" },
    { "key": "transSessionId", "value": "830016270356710161", "type": "string" }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Auto-inject credentials and (optionally) data_integrity_hash for every request.",
          "// Per USI spec the hash is SHA-256 of: concat(all POST params except username/password/pin/id1_scan/id2_scan/data_integrity_hash) + dataIntegrityKey.",
          "",
          "const username = pm.collectionVariables.get('username');",
          "const password = pm.collectionVariables.get('password');",
          "const pin = pm.collectionVariables.get('pin');",
          "const integrityKey = pm.collectionVariables.get('dataIntegrityKey');",
          "",
          "if (!pm.request.body || pm.request.body.mode !== 'urlencoded') return;",
          "",
          "// urlencoded fields are exposed as a Postman list; mutate via add()/upsert().",
          "function setField(name, value) {",
          "  if (value == null || value === '') return;",
          "  const existing = pm.request.body.urlencoded.find(f => f.key === name);",
          "  if (existing) existing.value = String(value);",
          "  else pm.request.body.urlencoded.add({ key: name, value: String(value), type: 'text' });",
          "}",
          "",
          "function removeField(name) {",
          "  const idx = pm.request.body.urlencoded.findIndex(f => f.key === name);",
          "  if (idx >= 0) pm.request.body.urlencoded.remove(idx);",
          "}",
          "",
          "setField('username', username);",
          "setField('password', password);",
          "setField('pin', pin);",
          "removeField('data_integrity_hash');",
          "",
          "if (integrityKey && integrityKey.length > 0) {",
          "  const exclude = new Set(['username', 'password', 'pin', 'id1_scan', 'id2_scan', 'data_integrity_hash']);",
          "  let concat = '';",
          "  pm.request.body.urlencoded.each((field) => {",
          "    if (field.disabled) return;",
          "    if (exclude.has(field.key)) return;",
          "    if (field.value == null) return;",
          "    concat += String(field.value);",
          "  });",
          "  // CryptoJS is bundled with Postman.",
          "  const hash = CryptoJS.SHA256(concat + integrityKey).toString(CryptoJS.enc.Hex);",
          "  setField('data_integrity_hash', hash);",
          "}"
        ]
      }
    }
  ],
