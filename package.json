{
  "name": "usi-payout-service",
  "version": "1.0.0",
  "description": "Secure payout microservice integrating with USI Money (RemitONE) Agent Partner API. Designed for high-concurrency production workloads with AWS KMS / Secrets Manager backed configuration.",
  "private": true,
  "main": "src/server.js",
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "start": "node src/server.js",
    "start:cluster": "node src/cluster.js",
    "dev": "NODE_ENV=development nodemon src/server.js",
    "lint": "eslint \"src/**/*.js\"",
    "test": "jest --runInBand --detectOpenHandles",
    "audit": "npm audit --omit=dev"
  },
  "dependencies": {
    "@aws-sdk/client-kms": "^3.687.0",
    "@aws-sdk/client-secrets-manager": "^3.687.0",
    "axios": "^1.7.7",
    "axios-retry": "^4.5.0",
    "compression": "^1.7.5",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "express-validator": "^7.2.0",
    "fast-xml-parser": "^4.5.0",
    "form-data": "^4.0.1",
    "helmet": "^8.0.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "rate-limit-redis": "^4.2.0",
    "redis": "^4.7.0",
    "uuid": "^11.0.3",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "eslint": "^9.15.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.7",
    "supertest": "^7.0.0"
  }
}
